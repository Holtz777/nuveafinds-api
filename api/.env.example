# HTTP server
PORT=8080

# OpenRouter (AI)
OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview
OPENROUTER_REFERER=https://nuveafinds.com
OPENROUTER_TITLE=Nuvea Finds API

# Pinterest OAuth 2.0
# Access token (obtido via OAuth flow). Se tiver refresh, o token store gerencia automaticamente.
PINTEREST_ACCESS_TOKEN=
# Client ID e Secret do app Pinterest (para refresh automatico de token)
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
# Refresh token (obtido junto com o access token no OAuth flow)
PINTEREST_REFRESH_TOKEN=
# Usar sandbox da API? (true/false). Sandbox funciona em Trial mode.
PINTEREST_SANDBOX=false

# Map board slug -> Pinterest board ID (comma-separated key=value pairs)
# Use GET /boards para listar suas boards e gerar este mapa
PINTEREST_BOARD_MAP=

# Optional: CORS allowed origin (use * for dev, tighten for prod)
CORS_ORIGIN=*
